# Supabase — create a project at https://supabase.com, then Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Service role key — server-only, used for admin user management. NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
# Optional: dedicated key for image generation (gpt-image-1). Falls back to OPENAI_API_KEY.
OPENAI_IMAGE_API_KEY=
# Optional model overrides
OPENAI_TEXT_MODEL=gpt-4o
OPENAI_IMAGE_MODEL=gpt-image-1

# Seed admin — the first admin account. After running the app, sign up with this email
# (or run `npm run seed:admin`) to be granted admin + active status automatically.
SEED_ADMIN_EMAIL=admin@sugimotovisa.com

# Public site URL (used for auth redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Odoo CRM (read-only import). Server-only.
ODOO_URL=https://odoo.yourcompany.org
ODOO_DB=your-odoo-database-name
ODOO_LOGIN=integration-user@yourcompany.org
ODOO_API_KEY=your-odoo-api-key

# Secret protecting the hourly Odoo cron route. Vercel sends it as a Bearer token.
CRON_SECRET=generate-a-long-random-string
